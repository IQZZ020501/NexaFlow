# Runtime environment: development, test, or production.
ENVIRONMENT=development

# PostgreSQL connection string used by FastAPI and Alembic.
DATABASE_URL=postgresql+psycopg://nexaflow:nexaflow@localhost:5432/nexaflow

# JWT signing secret. Replace this in any shared or production environment.
JWT_SECRET_KEY=dev-secret-change-me-please-replace

# Secret used to encrypt provider API keys at rest.
MODEL_SECRET_KEY=dev-model-secret-change-me-please-replace

# Directory used to store uploaded knowledge documents.
KNOWLEDGE_STORAGE_DIR=./storage/knowledge

# Access token lifetime in minutes.
JWT_EXPIRES_MINUTES=60

# Comma-separated frontend origins allowed by CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Initial global admin account created during bootstrap.
# The first login must change this password.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@nexaflow.local
BOOTSTRAP_ADMIN_NAME=NexaFlow Admin
BOOTSTRAP_ADMIN_PASSWORD=NexaFlow@123.

# Initial workspace and team created during bootstrap.
DEFAULT_WORKSPACE_NAME=Default Workspace
DEFAULT_WORKSPACE_SLUG=default
DEFAULT_TEAM_NAME=Default Team
DEFAULT_TEAM_SLUG=default
